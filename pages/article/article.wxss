/* 文章详情页样式 */
.article-container {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: var(--background-color);
  transition: background 0.3s;
}

.article-container.dark-mode {
  background: #000000;
}

.article-header {
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
  color: #FFFFFF;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.back-btn {
  min-width: 88rpx;
  min-height: 88rpx;
  min-width: 88rpx;
  width: 88rpx;
  min-height: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.back-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.theme-toggle {
  min-width: 88rpx;
  width: 88rpx;
  min-height: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.theme-icon {
  font-size: 36rpx;
  display: inline-block;
  transition: transform 0.3s;
}

.article-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.article-category {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
}

.article-date {
  font-size: 24rpx;
  opacity: 0.9;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.article-content {
  padding: 48rpx 32rpx;
}

.article-summary-box {
  padding: 24rpx;
  background: rgba(0, 122, 255, 0.08);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border-left: 4rpx solid var(--primary-color);
}

.dark-mode .article-summary-box {
  background: rgba(10, 132, 255, 0.15);
}

.article-summary {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary-color);
  line-height: 1.6;
}

/* 快速解答板块（新版） */
.quick-answers-box {
  padding: 32rpx;
  background: linear-gradient(135deg, #FFF9E6 0%, #FFE5B4 100%);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  border-left: 6rpx solid #FFB300;
  box-shadow: 0 4rpx 12rpx rgba(255, 179, 0, 0.2);
}

.dark-mode .quick-answers-box {
  background: linear-gradient(135deg, #3D2E00 0%, #4A3800 100%);
  border-left-color: #FFD60A;
  box-shadow: 0 4rpx 12rpx rgba(255, 214, 10, 0.15);
}

.quick-answers-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #F57C00;
  margin-bottom: 24rpx;
}

.dark-mode .quick-answers-title {
  color: #FFD60A;
}

.quick-answers-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.qa-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
}

.dark-mode .qa-item {
  background: rgba(255, 255, 255, 0.1);
}

.qa-question {
  font-size: 28rpx;
  font-weight: 700;
  color: #E65100;
  line-height: 1.4;
}

.dark-mode .qa-question {
  color: #FF9500;
}

.qa-answer {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
  padding-left: 16rpx;
}

.dark-mode .qa-answer {
  color: #E5E5E5;
}

/* 快速解答板块（旧版，向后兼容） */
.quick-answer-box {
  padding: 32rpx;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE5E5 100%);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  border-left: 6rpx solid #FF6B6B;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.2);
  position: relative;
  overflow: hidden;
}

.dark-mode .quick-answer-box {
  background: linear-gradient(135deg, #2D1F1F 0%, #3D2828 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 69, 58, 0.3);
}

.quick-answer-box::before {
  content: '⚡';
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 80rpx;
  opacity: 0.1;
}

.quick-answer-title {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #D32F2F;
  margin-bottom: 20rpx;
}

.dark-mode .quick-answer-title {
  color: #FF6B6B;
}

.quick-answer-tips {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quick-tip {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  padding: 12rpx 0;
  border-bottom: 1rpx dashed rgba(211, 47, 47, 0.2);
  font-weight: 500;
}

.dark-mode .quick-tip {
  color: #E5E5E5;
  border-bottom: 1rpx dashed rgba(255, 107, 107, 0.3);
}

.quick-tip:last-child {
  border-bottom: none;
}

.article-body {
  display: block;
}

.content-section {
  margin-bottom: 48rpx;
}

.section-heading {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.section-bullet,
.section-numbered {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.bullet-dot {
  font-size: 30rpx;
  color: #007AFF;
  font-weight: 700;
  line-height: 1.6;
}

.bullet-text {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.numbered-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.numbered-dot {
  font-size: 30rpx;
  color: #007AFF;
  font-weight: 700;
  line-height: 1.8;
  min-width: 40rpx;
}

.numbered-text {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.section-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.list-item {
  padding: 24rpx;
  background: var(--card-background);
  border-radius: 12rpx;
  border-left: 4rpx solid var(--primary-color);
}

.dark-mode .list-item {
  background: #1C1C1E;
}

.list-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.list-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.section-info {
  padding: 24rpx;
  background: rgba(52, 199, 89, 0.1);
  border-radius: 12rpx;
  border-left: 4rpx solid #34C759;
}

.info-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.article-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: var(--card-background);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.dark-mode .article-actions {
  background: #1C1C1E;
}

.action-btn {
  flex: 1;
  min-height: 88rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  background: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: opacity 0.2s, transform 0.1s;
}

.action-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.action-btn.outline {
  background: transparent;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}



/* 夜间模式下主题按钮增强反馈 */
.dark-mode .theme-toggle {
  box-shadow: 0 0 20rpx rgba(255, 214, 10, 0.4);
  background: rgba(255, 214, 10, 0.2);
}

/* 主题切换动画 */
@keyframes themeRotate {
  0% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.2); }
  100% { transform: rotate(360deg) scale(1); }
}

.theme-icon.icon-rotate {
  animation: themeRotate 0.5s ease-in-out;
}

/* 内容淡入动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.article-content {
  animation: fadeIn 0.4s ease-out;
}

/* 快速解答板块滑入动画 */
@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.quick-answers-box,
.quick-answer-box {
  animation: slideIn 0.5s ease-out;
}
/* 段落间距 - P2修复 */
.paragraph {
  margin-bottom: 48rpx;
}
