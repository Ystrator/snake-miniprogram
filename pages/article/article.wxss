/* 文章详情页样式 */
.article-container {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: var(--background-color);
  transition: background 0.3s;
}

.article-container.dark-mode {
  background: #000000;
}

.article-header {
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
  color: #FFFFFF;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.back-btn {
  min-width: 88rpx;
  min-height: 88rpx;
  min-width: 88rpx;
  width: 88rpx;
  min-height: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.back-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.theme-toggle {
  min-width: 88rpx;
  width: 88rpx;
  min-height: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.theme-icon {
  font-size: 36rpx;
  display: inline-block;
  transition: transform 0.3s;
}

.article-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.article-category {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
}

.article-date {
  font-size: 24rpx;
  opacity: 0.9;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.article-content {
  padding: 48rpx 32rpx;
}

.article-summary-box {
  padding: 24rpx;
  background: rgba(0, 122, 255, 0.08);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border-left: 4rpx solid var(--primary-color);
}

.dark-mode .article-summary-box {
  background: rgba(10, 132, 255, 0.15);
}

.article-summary {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary-color);
  line-height: 1.6;
}

/* 快速解答板块（新版） */
.quick-answers-box {
  padding: 32rpx;
  background: linear-gradient(135deg, #FFF9E6 0%, #FFE5B4 100%);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  border-left: 6rpx solid #FFB300;
  box-shadow: 0 4rpx 12rpx rgba(255, 179, 0, 0.2);
}

.dark-mode .quick-answers-box {
  background: linear-gradient(135deg, #3D2E00 0%, #4A3800 100%);
  border-left-color: #FFD60A;
  box-shadow: 0 4rpx 12rpx rgba(255, 214, 10, 0.15);
}

.quick-answers-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #F57C00;
  margin-bottom: 24rpx;
}

.dark-mode .quick-answers-title {
  color: #FFD60A;
}

.quick-answers-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.qa-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
}

.dark-mode .qa-item {
  background: rgba(255, 255, 255, 0.1);
}

.qa-question {
  font-size: 28rpx;
  font-weight: 700;
  color: #E65100;
  line-height: 1.4;
}

.dark-mode .qa-question {
  color: #FF9500;
}

.qa-answer {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
  padding-left: 16rpx;
}

.dark-mode .qa-answer {
  color: #E5E5E5;
}

/* 快速解答板块（旧版，向后兼容） */
.quick-answer-box {
  padding: 32rpx;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE5E5 100%);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  border-left: 6rpx solid #FF6B6B;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.2);
  position: relative;
  overflow: hidden;
}

.dark-mode .quick-answer-box {
  background: linear-gradient(135deg, #2D1F1F 0%, #3D2828 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 69, 58, 0.3);
}

.quick-answer-box::before {
  content: '⚡';
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 80rpx;
  opacity: 0.1;
}

.quick-answer-title {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #D32F2F;
  margin-bottom: 20rpx;
}

.dark-mode .quick-answer-title {
  color: #FF6B6B;
}

.quick-answer-tips {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quick-tip {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  padding: 12rpx 0;
  border-bottom: 1rpx dashed rgba(211, 47, 47, 0.2);
  font-weight: 500;
}

.dark-mode .quick-tip {
  color: #E5E5E5;
  border-bottom: 1rpx dashed rgba(255, 107, 107, 0.3);
}

.quick-tip:last-child {
  border-bottom: none;
}

.article-body {
  display: block;
}

.content-section {
  margin-bottom: 48rpx;
}

.section-heading {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.section-bullet,
.section-numbered {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.bullet-dot {
  font-size: 30rpx;
  color: #007AFF;
  font-weight: 700;
  line-height: 1.6;
}

.bullet-text {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.numbered-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.numbered-dot {
  font-size: 30rpx;
  color: #007AFF;
  font-weight: 700;
  line-height: 1.8;
  min-width: 40rpx;
}

.numbered-text {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.section-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.list-item {
  padding: 24rpx;
  background: var(--card-background);
  border-radius: 12rpx;
  border-left: 4rpx solid var(--primary-color);
}

.dark-mode .list-item {
  background: #1C1C1E;
}

.list-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.list-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.section-info {
  padding: 24rpx;
  background: rgba(52, 199, 89, 0.1);
  border-radius: 12rpx;
  border-left: 4rpx solid #34C759;
}

.info-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.article-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: var(--card-background);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.dark-mode .article-actions {
  background: #1C1C1E;
}

.action-btn {
  flex: 1;
  min-height: 88rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  background: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: opacity 0.2s, transform 0.1s;
}

.action-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.action-btn.outline {
  background: transparent;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}



/* 夜间模式下主题按钮增强反馈 */
.dark-mode .theme-toggle {
  box-shadow: 0 0 20rpx rgba(255, 214, 10, 0.4);
  background: rgba(255, 214, 10, 0.2);
}

/* 主题切换动画 */
@keyframes themeRotate {
  0% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.2); }
  100% { transform: rotate(360deg) scale(1); }
}

.theme-icon.icon-rotate {
  animation: themeRotate 0.5s ease-in-out;
}

/* 内容淡入动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.article-content {
  animation: fadeIn 0.4s ease-out;
}

/* 快速解答板块滑入动画 */
@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.quick-answers-box,
.quick-answer-box {
  animation: slideIn 0.5s ease-out;
}
/* 段落间距 - P2修复 */
.paragraph {
  margin-bottom: 48rpx;
}

/* ===== 相关文章推荐样式 ===== */

.related-articles-section {
  margin: 32rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(255,158,181,0.1), rgba(255,181,197,0.1));
  border-radius: 24rpx;
  border: 2rpx solid rgba(255,158,181,0.2);
}

.dark-mode .related-articles-section {
  background: linear-gradient(135deg, rgba(102,126,234,0.1), rgba(118,75,162,0.1));
  border-color: rgba(102,126,234,0.2);
}

.related-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.related-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.dark-mode .related-title {
  color: #FFF;
}

.related-badge {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: white;
  font-size: 22rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.related-article-card {
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  cursor: pointer;
  transition: all 0.3s;
}

.dark-mode .related-article-card {
  background: #3A3A3C;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.related-article-card:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.related-article-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.dark-mode .related-article-title {
  color: #FFF;
}

.related-article-summary {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.related-article-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.related-article-tag {
  font-size: 22rpx;
  color: #FF9EB5;
  background: rgba(255,158,181,0.1);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

.related-article-arrow {
  font-size: 24rpx;
  color: #FF9EB5;
}

/* ========== P3优化：视频支持 ========== */

/* 视频区域 */
.video-section {
  margin-bottom: 32rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--card-shadow);
}

.video-container {
  position: relative;
  width: 100%;
  height: 420rpx;
  background: #000;
}

.video-cover {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  opacity: 1;
}

.video-play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.play-icon {
  font-size: 36rpx;
  color: var(--primary-color);
  margin-left: 6rpx;
}

.video-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
}

.video-duration {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 12rpx;
  background: rgba(0, 0, 0, 0.7);
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.video-tip {
  font-size: 24rpx;
  color: #FFFFFF;
}

.video-player-wrapper {
  width: 100%;
  height: 420rpx;
  background: #000;
}

.video-player {
  width: 100%;
  height: 100%;
}

/* 内联视频 */
.inline-video {
  margin: 32rpx 0;
}

.inline-video-container {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: var(--soft-shadow);
}

.inline-video-cover {
  width: 100%;
  height: 100%;
  opacity: 0.9;
}

.inline-play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
}

.inline-play-btn .play-icon {
  font-size: 30rpx;
  color: var(--primary-color);
  margin-left: 4rpx;
}

.inline-video-title {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

/* 视频弹窗 */
.video-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.95);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-modal-content {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.video-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: rgba(0, 0, 0, 0.5);
}

.video-modal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.video-modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  font-size: 32rpx;
  color: #FFFFFF;
}

.video-modal-player {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.modal-video {
  width: 100%;
  max-height: 100%;
  border-radius: 16rpx;
  overflow: hidden;
}

/* 视频占位符渐变背景 */
.video-cover {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.inline-video-cover {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
