/* 文章详情页样式 */
.article-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.article-header {
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
}

.article-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.article-category {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
}

.article-date {
  font-size: 24rpx;
  opacity: 0.9;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.article-content {
  padding: 48rpx 32rpx;
}

.article-summary-box {
  padding: 24rpx;
  background: rgba(0, 122, 255, 0.05);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border-left: 4rpx solid #007AFF;
}

.article-summary {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #007AFF;
  line-height: 1.6;
}

/* 快速解答板块 */
.quick-answer-box {
  padding: 32rpx;
  background: linear-gradient(135deg, #FFE5E5 0%, #FFD1D1 100%);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  border-left: 6rpx solid #FF6B6B;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.15);
}

.quick-answer-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #D32F2F;
  margin-bottom: 20rpx;
}

.quick-answer-tips {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quick-tip {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed rgba(211, 47, 47, 0.2);
}

.quick-tip:last-child {
  border-bottom: none;
}

.article-body {
  display: block;
}

.content-section {
  margin-bottom: 48rpx;
}

.section-heading {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #E5E5EA;
}

.section-bullet,
.section-numbered {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.bullet-dot {
  font-size: 30rpx;
  color: #007AFF;
  font-weight: 700;
  line-height: 1.6;
}

.bullet-text {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

.numbered-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.numbered-dot {
  font-size: 30rpx;
  color: #007AFF;
  font-weight: 700;
  line-height: 1.8;
  min-width: 40rpx;
}

.numbered-text {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

.section-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.list-item {
  padding: 24rpx;
  background: #F9F9F9;
  border-radius: 12rpx;
  border-left: 4rpx solid #007AFF;
}

.list-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 8rpx;
}

.list-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.section-info {
  padding: 24rpx;
  background: rgba(52, 199, 89, 0.1);
  border-radius: 12rpx;
  border-left: 4rpx solid #34C759;
}

.info-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
}

.article-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  background: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: opacity 0.2s;
}

.action-btn:active {
  opacity: 0.7;
}

.action-btn.outline {
  background: transparent;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}
