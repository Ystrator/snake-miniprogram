/* 首页样式 - P0修复版 */

/* ========== 全局热区优化 - 统一88rpx ========== */
.large-tap {
  min-width: 88rpx !important;
  min-height: 88rpx !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* ========== 容器与背景 ========== */
.container {
  min-height: 100vh;
  background: var(--background-color);
  padding-bottom: 120rpx;
  transition: background 0.3s;
}

/* ========== 夜间模式优化 - 纯黑背景 + 低饱和度 ========== */

/* ========== 顶部状态栏 ========== */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--card-background);
}

.app-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.status-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.baby-age-badge {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.baby-age-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.baby-age-text {
  font-size: 24rpx;
  color: white;
  font-weight: bold;
}

.theme-toggle {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--background-color);
  border-radius: 50%;
}

.theme-icon {
  font-size: 40rpx;
}

/* ========== 宝宝年龄卡片 ========== */
.baby-age-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 20rpx;
}

.baby-age-content {
  display: flex;
  flex-direction: column;
}

.baby-age-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.baby-age-value {
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.baby-age-arrow {
  font-size: 32rpx;
  color: #667eea;
}

/* ========== 搜索英雄区 ========== */
.search-hero {
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
}

.search-box {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  flex: 1;
  font-size: 32rpx;
  color: #8E8E93;
  font-weight: 500;
}

.search-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ========== 紧急问题区 ========== */
.emergency-section {
  padding: 32rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: var(--card-background);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: all 0.2s;
}

.quick-btn:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.12);
}

.quick-emoji {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.quick-text {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 600;
}

/* ========== 核心功能区（新增 - 整合收藏入口） ========== */
.core-section {
  padding: 0 32rpx 32rpx;
}

.core-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.core-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s;
  min-height: 160rpx;
}

.core-card:active {
  transform: scale(0.97);
}

.core-emoji {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.core-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
}

/* ========== 推荐阅读区（精简版 - 只显示2篇） ========== */
.articles-section {
  padding: 32rpx;
}

.article-card {
  padding: 32rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s;
}

.article-card:active {
  transform: scale(0.98);
  background: var(--background-color);
}

.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  line-height: 1.8;
}

.article-summary {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ========== 弹窗 ========== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.emergency-modal {
  z-index: 1100;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(10rpx);
}

.modal-content {
  width: 600rpx;
  background: var(--card-background);
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalIn 0.3s;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.emergency-content {
  width: 640rpx;
  max-height: 80vh;
  background: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

@keyframes modalIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-close {
  font-size: 48rpx;
  color: var(--text-secondary);
  padding: 0 16rpx;
}

.modal-body {
  padding: 48rpx 32rpx;
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emergency-body {
  padding: 0;
  max-height: 60vh;
}

.emergency-scroll {
  height: 100%;
  padding: 32rpx;
}

.emergency-item {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.emergency-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.emergency-item-header {
  margin-bottom: 16rpx;
}

.emergency-item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF3B30;
  line-height: 1.8;
}

.emergency-steps {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  font-size: 28rpx;
  line-height: 2.0;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
  color: var(--text-primary);
}

.step-number {
  color: #667eea;
  font-weight: 700;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.step-text {
  flex: 1;
}

.tip-content {
  font-size: 32rpx;
  line-height: 1.8;
  color: var(--text-primary);
  text-align: center;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--border-color);
}

.modal-btn {
  width: 100%;
  padding: 24rpx;
  background: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* ========== 夜间模式特殊优化 ========== */
/* 纯黑背景 + 低饱和度 + 高对比度 */
.container.dark-mode .baby-age-card {
  background: rgba(102, 126, 234, 0.15);
  border-color: rgba(102, 126, 234, 0.3);
}

.container.dark-mode .search-hero {
  background: linear-gradient(135deg, #4A3F5C 0%, #6A5A7C 100%);
}

.container.dark-mode .core-card,
.container.dark-mode .article-card,
.container.dark-mode .quick-btn {
  background: #1A1A1A;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

.container.dark-mode .article-card:active {
  background: #252525;
}

.container.dark-mode .core-card:active,
.container.dark-mode .quick-btn:active {
  background: #252525;
}

.container.dark-mode .emergency-content {
  background: #1A1A1A;
}

.container.dark-mode .step-item {
  color: #E5E5E5;
}

/* ========== 健康工具区（新增）========== */
.health-tools-section {
  margin: 32rpx;
  margin-bottom: 40rpx;
}

.health-tools-grid {
  display: flex;
  gap: 20rpx;
  overflow-x: scroll;
  padding-bottom: 10rpx;
}

.health-tool-card {
  flex-shrink: 0;
  width: 280rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF4757 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 24rpx rgba(255, 75, 87, 0.25);
}

.health-tool-card:nth-child(2) {
  background: linear-gradient(135deg, #4ECDC4 0%, #26A69A 100%);
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.25);
}

.health-tool-card:nth-child(3) {
  background: linear-gradient(135deg, #A8E6CF 0%, #56AB2F 100%);
  box-shadow: 0 8rpx 24rpx rgba(168, 230, 207, 0.25);
}

.health-icon {
  font-size: 56rpx;
  margin-bottom: 15rpx;
}

.health-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.health-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

/* ========== 月龄推荐区（新增）========== */
.age-recommend-section {
  margin: 32rpx;
  margin-bottom: 40rpx;
}

.age-recommend-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.age-recommend-grid .article-card {
  background: linear-gradient(135deg, rgba(255, 158, 181, 0.1) 0%, rgba(255, 122, 157, 0.1) 100%);
  border: 2rpx solid rgba(255, 158, 181, 0.2);
}

.article-tags {
  display: flex;
  gap: 10rpx;
  margin-top: 15rpx;
}

.article-tag {
  font-size: 22rpx;
  color: #FF9EB5;
  padding: 5rpx 15rpx;
  background: rgba(255, 158, 181, 0.1);
  border-radius: 20rpx;
}

.view-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 25rpx;
  background: white;
  border-radius: 50rpx;
  margin-top: 20rpx;
  color: #FF9EB5;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.dark .view-more-btn {
  background: #2C2C2E;
  color: #FF9EB5;
}

/* ===== AI个性化推荐样式 ===== */

/* 推荐区块 */
.ai-recommend-section,
.trending-section {
  margin: 32rpx 0;
  padding: 32rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.dark-mode .ai-recommend-section,
.dark-mode .trending-section {
  background: #2C2C2E;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.3);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.recommend-badge {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: white;
  font-size: 22rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.trending-badge {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #F093FB, #F5576C);
  color: white;
  font-size: 22rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

/* 文章元信息 */
.article-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F2F2F7;
}

.dark-mode .article-meta {
  border-top: 1rpx solid #3A3A3C;
}

.recommend-score,
.trend-score {
  font-size: 22rpx;
  color: #FF9EB5;
  font-weight: bold;
}

/* 相关文章推荐样式 */
.related-articles-section {
  margin: 32rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(255,158,181,0.1), rgba(255,181,197,0.1));
  border-radius: 24rpx;
  border: 2rpx solid rgba(255,158,181,0.2);
}

.dark-mode .related-articles-section {
  background: linear-gradient(135deg, rgba(102,126,234,0.1), rgba(118,75,162,0.1));
  border-color: rgba(102,126,234,0.2);
}

.related-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.related-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.dark-mode .related-title {
  color: #FFF;
}

.related-badge {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: white;
  font-size: 22rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.related-article-card {
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  cursor: pointer;
  transition: all 0.3s;
}

.dark-mode .related-article-card {
  background: #3A3A3C;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.related-article-card:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.related-article-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.dark-mode .related-article-title {
  color: #FFF;
}

.related-article-summary {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.related-article-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.related-article-tag {
  font-size: 22rpx;
  color: #FF9EB5;
  background: rgba(255,158,181,0.1);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

.related-article-arrow {
  font-size: 24rpx;
  color: #FF9EB5;
}

/* ========== P3优化：专家服务板块 ========== */

.expert-section {
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.expert-cards {
  display: flex;
  gap: 16rpx;
}

.expert-card {
  flex: 1;
  padding: 32rpx 24rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  box-shadow: var(--card-shadow);
  transition: all 0.3s;
}

.expert-card:active {
  transform: scale(0.97);
}

.expert-card.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
}

.expert-card.secondary {
  background: linear-gradient(135deg, #88C9A8 0%, #6BA88E 100%);
  color: #FFFFFF;
}

.expert-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.expert-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.expert-desc {
  display: block;
  font-size: 22rpx;
  opacity: 0.9;
}

.expert-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 12rpx;
}

/* 暗黑模式适配 */
.dark-mode .expert-card.secondary {
  background: linear-gradient(135deg, #5A8A6E 0%, #4A786E 100%);
}
