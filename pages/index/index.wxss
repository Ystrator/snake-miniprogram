/* 首页样式 - 新手妈妈友好版 */
.container {
  min-height: 100vh;
  background: var(--background-color);
  padding-bottom: 120rpx;
  transition: background 0.3s;
}

/* 夜间模式 */
.container.dark-mode {
  background: #000000;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--card-background);
}

.app-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.status-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.baby-age-badge {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.baby-age-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.baby-age-text {
  font-size: 24rpx;
  color: white;
  font-weight: bold;
}

.theme-toggle {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--background-color);
  border-radius: 50%;
}

.theme-icon {
  font-size: 40rpx;
}

/* 宝宝年龄卡片 */
.baby-age-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 20rpx;
}

.baby-age-content {
  display: flex;
  flex-direction: column;
}

.baby-age-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.baby-age-value {
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.baby-age-arrow {
  font-size: 32rpx;
  color: #667eea;
}

/* 搜索英雄区 */
.search-hero {
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
}

.search-box {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  flex: 1;
  font-size: 32rpx;
  color: #8E8E93;
  font-weight: 500;
}

.search-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 紧急问题区 */
.emergency-section {
  padding: 32rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: var(--card-background);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx var(--shadow-color);
  transition: all 0.2s;
}

.quick-btn:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.12);
}

.quick-emoji {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.quick-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
}

/* 年龄区 */
.age-section {
  padding: 0 32rpx 32rpx;
}

.age-cards {
  display: flex;
  gap: 16rpx;
}

.age-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
  transition: all 0.2s;
}

.age-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.age-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.age-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.age-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 紧急情况快速指南区 */
.emergency-guide-section {
  padding: 0 32rpx 32rpx;
}

.emergency-btn {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #FF3B30 0%, #FF6B6B 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 59, 48, 0.3);
  transition: all 0.2s;
}

.emergency-btn:active {
  transform: scale(0.98);
}

.emergency-icon {
  font-size: 64rpx;
  margin-right: 16rpx;
}

.emergency-text {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.emergency-arrow {
  font-size: 56rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 文章区 */
.articles-section {
  padding: 32rpx;
}

.article-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
  transition: all 0.2s;
}

.article-card:active {
  transform: scale(0.98);
  background: var(--background-color);
}

.article-left {
  flex: 1;
}

.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.article-summary {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.mini-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: rgba(0, 122, 255, 0.1);
  color: #007AFF;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.article-arrow {
  font-size: 56rpx;
  color: var(--text-secondary);
  margin-left: 16rpx;
  font-weight: 300;
}

/* 每日小贴士 */
.tip-section {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin: 0 32rpx 32rpx;
  background: linear-gradient(135deg, #FFA07A 0%, #FF6B6B 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
  transition: all 0.2s;
}

.tip-section:active {
  transform: scale(0.98);
}

.tip-icon {
  font-size: 64rpx;
  margin-right: 16rpx;
}

.tip-text {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.tip-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.emergency-modal {
  z-index: 1100;
}

.modal-content {
  width: 600rpx;
  background: var(--card-background);
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalIn 0.3s;
}

.emergency-content {
  width: 640rpx;
  max-height: 80vh;
}

@keyframes modalIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-close {
  font-size: 48rpx;
  color: var(--text-secondary);
  padding: 0 16rpx;
}

.modal-body {
  padding: 48rpx 32rpx;
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emergency-body {
  padding: 0;
  max-height: 60vh;
}

.emergency-scroll {
  height: 100%;
  padding: 32rpx;
}

.emergency-item {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.emergency-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.emergency-item-header {
  margin-bottom: 16rpx;
}

.emergency-item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--danger-color);
  line-height: 1.4;
}

.emergency-steps {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

.step-number {
  color: var(--primary-color);
  font-weight: 700;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.step-text {
  flex: 1;
}

.tip-content {
  font-size: 32rpx;
  line-height: 1.8;
  color: var(--text-primary);
  text-align: center;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--border-color);
}

.modal-btn {
  width: 100%;
  padding: 24rpx;
  background: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
}
