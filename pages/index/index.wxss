/* 首页样式 - P0修复版 */

/* ========== 全局热区优化 - 统一88rpx ========== */
.large-tap {
  min-width: 88rpx !important;
  min-height: 88rpx !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* ========== 容器与背景 ========== */
.container {
  min-height: 100vh;
  background: var(--background-color);
  padding-bottom: 120rpx;
  transition: background 0.3s;
}

/* ========== 夜间模式优化 - 纯黑背景 + 低饱和度 ========== */
.container.dark-mode {
  background: #000000;
}

/* ========== 顶部状态栏 ========== */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--card-background);
}

.app-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.status-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.baby-age-badge {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.baby-age-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.baby-age-text {
  font-size: 24rpx;
  color: white;
  font-weight: bold;
}

.theme-toggle {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--background-color);
  border-radius: 50%;
}

.theme-icon {
  font-size: 40rpx;
}

/* ========== 宝宝年龄卡片 ========== */
.baby-age-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 20rpx;
}

.baby-age-content {
  display: flex;
  flex-direction: column;
}

.baby-age-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.baby-age-value {
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.baby-age-arrow {
  font-size: 32rpx;
  color: #667eea;
}

/* ========== 搜索英雄区 ========== */
.search-hero {
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
}

.search-box {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  flex: 1;
  font-size: 32rpx;
  color: #8E8E93;
  font-weight: 500;
}

.search-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ========== 紧急问题区 ========== */
.emergency-section {
  padding: 32rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: var(--card-background);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: all 0.2s;
}

.quick-btn:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.12);
}

.quick-emoji {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.quick-text {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 600;
}

/* ========== 核心功能区（新增 - 整合收藏入口） ========== */
.core-section {
  padding: 0 32rpx 32rpx;
}

.core-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.core-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s;
  min-height: 160rpx;
}

.core-card:active {
  transform: scale(0.97);
}

.core-emoji {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.core-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
}

/* ========== 推荐阅读区（精简版 - 只显示2篇） ========== */
.articles-section {
  padding: 32rpx;
}

.article-card {
  padding: 32rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s;
}

.article-card:active {
  transform: scale(0.98);
  background: var(--background-color);
}

.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  line-height: 1.8;
}

.article-summary {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ========== 弹窗 ========== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.emergency-modal {
  z-index: 1100;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(10rpx);
}

.modal-content {
  width: 600rpx;
  background: var(--card-background);
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalIn 0.3s;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.emergency-content {
  width: 640rpx;
  max-height: 80vh;
  background: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

@keyframes modalIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-close {
  font-size: 48rpx;
  color: var(--text-secondary);
  padding: 0 16rpx;
}

.modal-body {
  padding: 48rpx 32rpx;
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emergency-body {
  padding: 0;
  max-height: 60vh;
}

.emergency-scroll {
  height: 100%;
  padding: 32rpx;
}

.emergency-item {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.emergency-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.emergency-item-header {
  margin-bottom: 16rpx;
}

.emergency-item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF3B30;
  line-height: 1.8;
}

.emergency-steps {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  font-size: 28rpx;
  line-height: 2.0;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
  color: var(--text-primary);
}

.step-number {
  color: #667eea;
  font-weight: 700;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.step-text {
  flex: 1;
}

.tip-content {
  font-size: 32rpx;
  line-height: 1.8;
  color: var(--text-primary);
  text-align: center;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--border-color);
}

.modal-btn {
  width: 100%;
  padding: 24rpx;
  background: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* ========== 夜间模式特殊优化 ========== */
/* 纯黑背景 + 低饱和度 + 高对比度 */
.container.dark-mode .baby-age-card {
  background: rgba(102, 126, 234, 0.15);
  border-color: rgba(102, 126, 234, 0.3);
}

.container.dark-mode .search-hero {
  background: linear-gradient(135deg, #4A3F5C 0%, #6A5A7C 100%);
}

.container.dark-mode .core-card,
.container.dark-mode .article-card,
.container.dark-mode .quick-btn {
  background: #1A1A1A;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

.container.dark-mode .article-card:active {
  background: #252525;
}

.container.dark-mode .core-card:active,
.container.dark-mode .quick-btn:active {
  background: #252525;
}

.container.dark-mode .emergency-content {
  background: #1A1A1A;
}

.container.dark-mode .step-item {
  color: #E5E5E5;
}
