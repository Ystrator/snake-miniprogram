<!--首页 - P3优化版本（新增服务入口）-->
<view class="container {{darkMode ? 'dark-mode' : ''}}">
  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <text class="app-name">育儿知识大全</text>
    <view class="status-actions">
      <view class="baby-age-badge large-tap" bindtap="goToBaby" wx:if="{{babyAgeText}}">
        <text class="baby-age-icon">👶</text>
        <text class="baby-age-text">{{babyAgeText}}</text>
      </view>
      <view class="theme-toggle large-tap" bindtap="toggleDarkMode">
        <text class="theme-icon">{{darkMode ? '☀️' : '🌙'}}</text>
      </view>
    </view>
  </view>

  <!-- 宝宝年龄卡片 -->
  <view class="baby-age-card large-tap" wx:if="{{babyAgeText}}" bindtap="goToBaby">
    <view class="baby-age-content">
      <text class="baby-age-label">{{babyName}}</text>
      <text class="baby-age-value">今天 {{babyAgeText}} 啦！</text>
    </view>
    <text class="baby-age-arrow">→</text>
  </view>

  <!-- 搜索区 -->
  <view class="search-hero large-tap" bindtap="goToSearch">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">试试搜索：不睡觉、哭闹、发烧、喂养...</text>
    </view>
    <text class="search-hint">AI智能搜索，精准匹配</text>
  </view>

  <!-- 健康工具区 -->
  <view class="health-tools-section">
    <text class="section-title">🏥 健康工具</text>
    <view class="health-tools-grid">
      <view class="health-tool-card large-tap" bindtap="goToFever">
        <text class="health-icon">🌡️</text>
        <text class="health-title">发烧护理</text>
        <text class="health-desc">体温记录+护理指南</text>
      </view>
      <view class="health-tool-card large-tap" bindtap="goToGrowth">
        <text class="health-icon">📊</text>
        <text class="health-title">成长曲线</text>
        <text class="health-desc">身高体重WHO对比</text>
      </view>
      <view class="health-tool-card large-tap" bindtap="goToVaccine">
        <text class="health-icon">💉</text>
        <text class="health-title">疫苗提醒</text>
        <text class="health-desc">接种时间记录提醒</text>
      </view>
    </view>
  </view>

  <!-- P3新增：专家问答入口 -->
  <view class="expert-section">
    <text class="section-title">👨‍⚕️ 专家服务</text>
    <view class="expert-cards">
      <view class="expert-card primary large-tap" bindtap="goToExpert">
        <text class="expert-icon">💬</text>
        <text class="expert-title">专家问答</text>
        <text class="expert-desc">专业医生在线解答</text>
        <text class="expert-badge">NEW</text>
      </view>
      <view class="expert-card secondary large-tap" bindtap="goToNearby">
        <text class="expert-icon">🏥</text>
        <text class="expert-title">附近服务</text>
        <text class="expert-desc">发现身边的医院</text>
      </view>
    </view>
  </view>

  <!-- 快捷问题入口 -->
  <view class="emergency-section">
    <text class="section-title">🚨 宝宝遇到问题？</text>
    <view class="quick-grid">
      <view class="quick-btn large-tap" bindtap="searchKeyword" data-keyword="不睡觉">
        <text class="quick-emoji">😴</text>
        <text class="quick-text">不睡觉</text>
      </view>
      <view class="quick-btn large-tap" bindtap="searchKeyword" data-keyword="哭闹">
        <text class="quick-emoji">😭</text>
        <text class="quick-text">哭闹</text>
      </view>
      <view class="quick-btn large-tap" bindtap="searchKeyword" data-keyword="发烧">
        <text class="quick-emoji">🤒</text>
        <text class="quick-text">发烧</text>
      </view>
      <view class="quick-btn large-tap" bindtap="searchKeyword" data-keyword="不吃饭">
        <text class="quick-emoji">🍼</text>
        <text class="quick-text">不吃饭</text>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="core-section">
    <text class="section-title">✨ 快捷入口</text>
    <view class="core-grid">
      <view class="core-card large-tap" bindtap="goToCategory" data-id="age-0-1">
        <text class="core-emoji">👶</text>
        <text class="core-title">知识库</text>
      </view>
      <view class="core-card large-tap" bindtap="goToFavorites">
        <text class="core-emoji">⭐</text>
        <text class="core-title">我的收藏</text>
      </view>
      <view class="core-card large-tap" bindtap="showEmergencyGuide">
        <text class="core-emoji">🚨</text>
        <text class="core-title">紧急指南</text>
      </view>
      <view class="core-card large-tap" bindtap="showDailyTip">
        <text class="core-emoji">💡</text>
        <text class="core-title">每日小贴士</text>
      </view>
    </view>
  </view>

  <!-- AI个性化推荐 -->
  <view class="ai-recommend-section" wx:if="{{showPersonalized && personalizedArticles.length > 0}}">
    <view class="section-header">
      <text class="section-title">🤖 为你推荐</text>
      <text class="recommend-badge">AI</text>
    </view>
    <view class="article-list">
      <view 
        class="article-card large-tap" 
        wx:for="{{personalizedArticles}}" 
        wx:key="id" 
        bindtap="readArticle" 
        data-id="{{item.id}}"
      >
        <text class="article-title">{{item.title}}</text>
        <text class="article-summary">{{item.summary}}</text>
        <view class="article-meta">
          <text class="article-tag">{{item.categoryName}}</text>
          <text class="recommend-score">推荐度 {{item.recommendationScore ? (item.recommendationScore * 100).toFixed(0) : 85}}%</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 热门文章 -->
  <view class="trending-section" wx:if="{{trendingArticles.length > 0}}">
    <view class="section-header">
      <text class="section-title">🔥 热门文章</text>
      <text class="trending-badge">HOT</text>
    </view>
    <view class="article-list">
      <view 
        class="article-card large-tap" 
        wx:for="{{trendingArticles}}" 
        wx:key="id" 
        wx:if="{{index < 3}}"
        bindtap="readArticle" 
        data-id="{{item.id}}"
      >
        <text class="article-title">{{item.title}}</text>
        <text class="article-summary">{{item.summary}}</text>
        <view class="article-meta">
          <text class="article-tag">{{item.categoryName}}</text>
          <text class="trend-score">🔥 {{item.trendScore ? item.trendScore.toFixed(0) : 100}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 月龄推荐 -->
  <view class="age-recommend-section" wx:if="{{hotArticles.length > 0}}">
    <text class="section-title">📚 {{babyAgeText ? '适合' + babyName : '推荐阅读'}}</text>
    <view class="article-list">
      <view 
        class="article-card large-tap" 
        wx:for="{{hotArticles}}" 
        wx:key="id" 
        wx:if="{{index < 3}}" 
        bindtap="readArticle" 
        data-id="{{item.id}}"
      >
        <text class="article-title">{{item.title}}</text>
        <text class="article-summary">{{item.summary}}</text>
        <view class="article-tags">
          <text class="article-tag">{{item.categoryName}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 紧急情况快速指南弹窗 -->
<view class="modal emergency-modal" wx:if="{{showEmergencyModal}}" bindtap="hideEmergencyGuide">
  <view class="modal-content emergency-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">🚨 紧急情况快速指南</text>
      <text class="modal-close large-tap" bindtap="hideEmergencyGuide">✕</text>
    </view>
    <view class="modal-body emergency-body">
      <scroll-view scroll-y class="emergency-scroll">
        <view class="emergency-item" wx:for="{{emergencyGuide}}" wx:key="id">
          <view class="emergency-item-header">
            <text class="emergency-item-title">{{item.title}}</text>
          </view>
          <view class="emergency-steps">
            <text class="step-item" wx:for="{{item.steps}}" wx:key="*this" wx:for-item="step" wx:for-index="idx">
              <text class="step-number">{{idx + 1}}.</text>
              <text class="step-text">{{step}}</text>
            </text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>

<!-- 每日小贴士弹窗 -->
<view class="modal tip-modal" wx:if="{{showTipModal}}" bindtap="hideDailyTip">
  <view class="modal-content tip-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">💡 每日小贴士</text>
      <text class="modal-close large-tap" bindtap="hideDailyTip">✕</text>
    </view>
    <view class="modal-body tip-body">
      <text class="tip-text">{{dailyTip}}</text>
    </view>
  </view>
</view>
