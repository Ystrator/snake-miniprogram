/* pages/profile/profile.wxss */
.profile-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  padding: 40rpx 30rpx;
}

.profile-container.dark {
  background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.dark .title {
  color: #fff;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.dark .subtitle {
  color: #aaa;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 40rpx;
}

.dark .form-card {
  background: #3a4a5a;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.dark .label {
  color: #eee;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.dark .input {
  background: #4a5a6a;
  color: #fff;
}

.picker {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.dark .picker {
  background: #4a5a6a;
  color: #fff;
}

.gender-selector {
  display: flex;
  gap: 20rpx;
}

.gender-option {
  flex: 1;
  height: 120rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.dark .gender-option {
  background: #4a5a6a;
}

.gender-option.active {
  border-color: #ffb6c1;
  background: rgba(255, 182, 193, 0.1);
}

.gender-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.gender-text {
  font-size: 24rpx;
  color: #666;
}

.dark .gender-text {
  color: #aaa;
}

.btn-save {
  height: 88rpx;
  background: linear-gradient(135deg, #ffb6c1 0%, #ff69b4 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 105, 180, 0.3);
}

.btn-save text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.btn-delete {
  height: 88rpx;
  background: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ff4757;
}

.dark .btn-delete {
  background: #3a4a5a;
}

.btn-delete text {
  font-size: 28rpx;
  color: #ff4757;
}

.age-info {
  margin-top: 40rpx;
}

.age-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.dark .age-card {
  background: #3a4a5a;
}

.age-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.dark .age-label {
  color: #888;
}

.age-value {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #ff69b4;
}

.age-tip {
  text-align: center;
  padding: 0 20rpx;
}

.age-tip text {
  font-size: 24rpx;
  color: #999;
}

.dark .age-tip text {
  color: #888;
}
