<!--分类页面-->
<view class="container {{darkMode ? 'dark-mode' : ''}}">
  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <text class="page-title">分类浏览</text>
    <view class="theme-toggle" bindtap="toggleDarkMode">
      <text class="theme-icon">{{darkMode ? '☀️' : '🌙'}}</text>
    </view>
  </view>

  <view class="category-list">
    <view class="category-card" wx:for="{{categories}}" wx:key="id" bindtap="selectCategory" data-id="{{item.id}}">
      <view class="category-icon">{{item.icon}}</view>
      <view class="category-info">
        <text class="category-name">{{item.name}}</text>
        <text class="category-desc">{{item.description}}</text>
        <text class="article-count">{{item.articles.length}} 篇文章</text>
      </view>
    </view>
  </view>

  <!-- 文章列表（选择分类后显示） -->
  <view class="article-section" wx:if="{{selectedCategory}}">
    <view class="section-header">
      <text class="section-title">{{selectedCategory.name}}</text>
    </view>
    <view class="article-list">
      <view class="article-item" wx:for="{{selectedCategory.articles}}" wx:key="id" bindtap="readArticle" data-article="{{item}}">
        <text class="article-title">{{item.title}}</text>
        <text class="article-summary">{{item.summary}}</text>
        <view class="article-meta">
          <text class="article-date">{{item.publishDate}}</text>
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
