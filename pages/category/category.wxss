/* 分类页面样式 */
.container {
  min-height: 100vh;
  padding: 32rpx;
  background: var(--background-color);
  transition: background 0.3s;
}

.container.dark-mode {
  background: #000000;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.theme-toggle {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-background);
  border-radius: 50%;
}

.theme-icon {
  font-size: 40rpx;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.category-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
  transition: transform 0.2s;
}

.category-card:active {
  transform: scale(0.98);
}

.category-icon {
  font-size: 80rpx;
  margin-right: 24rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.category-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.article-count {
  display: block;
  font-size: 24rpx;
  color: var(--primary-color);
}

.article-section {
  margin-top: 48rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.article-item {
  padding: 32rpx;
  background: var(--card-background);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx var(--shadow-color);
}

.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.article-summary {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.article-date {
  font-size: 24rpx;
  color: var(--text-secondary);
}
