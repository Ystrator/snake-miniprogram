/* 分类页面样式 */
.container {
  min-height: 100vh;
  padding: 32rpx;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.category-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}

.category-card:active {
  transform: scale(0.98);
}

.category-icon {
  font-size: 80rpx;
  margin-right: 24rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 8rpx;
}

.category-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.article-count {
  display: block;
  font-size: 24rpx;
  color: var(--primary-color);
}

.article-section {
  margin-top: 48rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #000;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.article-item {
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 12rpx;
}

.article-summary {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.article-date {
  font-size: 24rpx;
  color: var(--text-secondary);
}
