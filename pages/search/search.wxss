/* 搜索页面样式 - 优化版本 */
.container {
  min-height: 100vh;
  padding: 32rpx;
  background: var(--background-color);
  transition: background 0.3s;
}

.container.dark-mode {
  background: #000000;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.theme-toggle {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-background);
  border-radius: 50%;
}

.theme-icon {
  font-size: 40rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--card-background);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
  margin-bottom: 32rpx;
}

.search-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  padding: 0 16rpx;
}

.voice-btn {
  font-size: 40rpx;
  padding: 8rpx 16rpx;
  margin-right: 8rpx;
}

.search-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 搜索历史 */
.search-history {
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: var(--card-background);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx var(--shadow-color);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.history-clear {
  font-size: 24rpx;
  color: #667eea;
  padding: 8rpx 16rpx;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-item {
  padding: 12rpx 24rpx;
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  border-radius: 24rpx;
  font-size: 26rpx;
}

/* 搜索结果区域 */
.search-results-scroll {
  height: calc(100vh - 400rpx);
}

.search-results {
  margin-top: 32rpx;
}

.result-count {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  padding-left: 16rpx;
}

/* 文章卡片 */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.article-card {
  display: flex;
  padding: 24rpx;
  background: var(--card-background);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.article-card.top-match {
  border-color: #667eea;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
}

/* 图标占位符 */
.article-icon-placeholder {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.placeholder-icon {
  font-size: 40rpx;
}

.article-content {
  flex: 1;
  overflow: hidden;
}

.article-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.article-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.badges {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.badge {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.badge.hot {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.badge.recommend {
  background: linear-gradient(135deg, #ffeaa7 0%, #fdcb6e 100%);
  color: #d63031;
}

.article-description {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.article-category {
  font-size: 24rpx;
  color: #667eea;
  padding: 6rpx 16rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 12rpx;
  font-weight: 500;
}

.article-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  color: var(--text-secondary);
  padding: 4rpx 10rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 8rpx;
}

.dark .tag {
  background: rgba(255, 255, 255, 0.1);
}

/* 相关文章推荐 */
.related-section {
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
}

.dark .related-section {
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.related-header {
  margin-bottom: 20rpx;
}

.related-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.related-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: var(--card-background);
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx var(--shadow-color);
}

.related-title-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.related-arrow {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 热门搜索 */
.search-tips {
  margin-top: 48rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  padding-left: 16rpx;
}

.tags-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--card-background);
  color: #667eea;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx var(--shadow-color);
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.tag-count {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
  padding: 2rpx 8rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 10rpx;
}

.dark .tag-count {
  background: rgba(255, 255, 255, 0.1);
}
/* 搜索高亮样式 */
.highlight {
  color: #FF3B30;
  font-weight: 700;
  background: rgba(255, 59, 48, 0.1);
  padding: 0 4rpx;
  border-radius: 4rpx;
}

/* ===== AI智能搜索样式 ===== */

/* 搜索建议 */
.search-suggestions {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: white;
  border-radius: 0 0 12rpx 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  z-index: 100;
  max-height: 400rpx;
  overflow-y: auto;
}

.dark-mode .search-suggestions {
  background: #2C2C2E;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

.suggestion-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F2F2F7;
  cursor: pointer;
}

.dark-mode .suggestion-item {
  border-bottom: 1rpx solid #3A3A3C;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.suggestion-text {
  font-size: 28rpx;
  color: #333;
}

.dark-mode .suggestion-text {
  color: #FFF;
}

/* 搜索结果头部 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #FF9EB5 0%, #FFB5C5 100%);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.result-count {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

.ai-badge {
  font-size: 24rpx;
  background: rgba(255,255,255,0.3);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  color: white;
}

/* AI匹配文章卡片 */
.article-card.ai-match {
  border-left: 4rpx solid #FF9EB5;
  background: linear-gradient(to right, rgba(255,158,181,0.05), transparent);
}

.article-card.recommend-match {
  border-left: 4rpx solid #FFB5C5;
  background: linear-gradient(to right, rgba(255,181,197,0.05), transparent);
}

.badge.ai {
  background: linear-gradient(135deg, #FF9EB5, #FFB5C5);
  color: white;
}

.badge.recommend {
  background: linear-gradient(135deg, #FFB5C5, #FFD1DC);
  color: white;
}

/* 空状态建议 */
.empty-suggestions {
  margin-top: 48rpx;
  padding: 32rpx;
  background: #F2F2F7;
  border-radius: 16rpx;
}

.dark-mode .empty-suggestions {
  background: #2C2C2E;
}

.suggestions-title {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.suggestions-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.suggestion-chip {
  padding: 16rpx 24rpx;
  background: white;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #FF9EB5;
  border: 1rpx solid #FF9EB5;
  cursor: pointer;
}

.dark-mode .suggestion-chip {
  background: #3A3A3C;
  color: #FFB5C5;
  border-color: #FFB5C5;
}

.suggestion-chip:active {
  opacity: 0.7;
}

/* 月龄筛选条 */
.age-filter-bar {
  margin-top: 20rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin-right: 15rpx;
  background: var(--background-color);
  border-radius: 50rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.filter-item.active {
  background: linear-gradient(135deg, #FF9EB5 0%, #FF7A9D 100%);
  color: white;
  border-color: #FF9EB5;
}

.filter-badge {
  padding: 5rpx 15rpx;
  background: rgba(255, 158, 181, 0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #FF9EB5;
}
