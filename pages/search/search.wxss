/* 搜索页面样式 */
.container {
  min-height: 100vh;
  padding: 32rpx;
  background: var(--background-color);
  transition: background 0.3s;
}

.container.dark-mode {
  background: #000000;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.theme-toggle {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-background);
  border-radius: 50%;
}

.theme-icon {
  font-size: 40rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--card-background);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
  margin-bottom: 32rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  padding: 0 16rpx;
}

.search-btn {
  padding: 16rpx 32rpx;
  background: var(--primary-color);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.search-results {
  margin-top: 32rpx;
}

.result-count {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  padding-left: 16rpx;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.article-item {
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.article-summary {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.article-category {
  font-size: 24rpx;
  color: var(--primary-color);
  padding: 4rpx 12rpx;
  background: rgba(0, 122, 255, 0.1);
  border-radius: 12rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.search-tips {
  margin-top: 48rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  padding-left: 16rpx;
}

.tags-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 16rpx 32rpx;
  background: var(--card-background);
  color: var(--primary-color);
  border-radius: 32rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx var(--shadow-color);
}
