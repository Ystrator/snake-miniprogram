<!--搜索页面 - 月龄筛选增强版-->
<view class="container {{darkMode ? 'dark-mode' : ''}}">
  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <text class="page-title">搜索</text>
    <view class="theme-toggle" bindtap="toggleDarkMode">
      <text class="theme-icon">{{darkMode ? '☀️' : '🌙'}}</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar-wrapper">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input"
        placeholder="试试搜索：宝宝不睡觉、哭闹、发烧..."
        value="{{keyword}}"
        bindinput="onInput"
        confirm-type="search"
        bindconfirm="doSearch" 
      />
      <text class="clear-btn" bindtap="clearInput" wx:if="{{keyword}}">✕</text>
      <text class="search-btn" bindtap="doSearch">搜索</text>
    </view>

    <!-- 月龄筛选 -->
    <view class="age-filter-bar" wx:if="{{hasBabyInfo || currentAgeFilter !== 'all'}}">
      <scroll-view scroll-x class="filter-scroll">
        <view class="filter-item {{currentAgeFilter === 'all' ? 'active' : ''}}" bindtap="switchAgeFilter" data-id="all">
          <text>全部</text>
        </view>
        <view class="filter-item {{currentAgeFilter === 'age-0-1' ? 'active' : ''}}" bindtap="switchAgeFilter" data-id="age-0-1">
          <text>0-1岁</text>
        </view>
        <view class="filter-item {{currentAgeFilter === 'age-1-3' ? 'active' : ''}}" bindtap="switchAgeFilter" data-id="age-1-3">
          <text>1-3岁</text>
        </view>
        <view class="filter-item {{currentAgeFilter === 'age-3-6' ? 'active' : ''}}" bindtap="switchAgeFilter" data-id="age-3-6">
          <text>3-6岁</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 搜索历史 -->
  <view class="search-history" wx:if="{{!searched && searchHistory.length > 0}}">
    <view class="history-header">
      <text class="history-title">🕐 搜索历史</text>
      <text class="history-clear" bindtap="clearSearchHistory">清空</text>
    </view>
    <view class="history-list">
      <text 
        class="history-item" 
        wx:for="{{searchHistory}}" 
        wx:key="*this" 
        bindtap="clickHistoryItem" 
        data-keyword="{{item}}"
      >
        {{item}}
      </text>
    </view>
  </view>

  <!-- 热门标签 -->
  <view class="hot-tags" wx:if="{{!searched}}">
    <text class="hot-title">🔥 热门搜索</text>
    <view class="tag-list">
      <text 
        class="tag-item" 
        wx:for="{{hotTags}}" 
        wx:key="tag" 
        bindtap="clickHotTag" 
        data-tag="{{item.tag}}"
      >
        {{item.tag}}
      </text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <scroll-view 
    class="search-results-scroll" 
    scroll-y="true" 
    wx:if="{{searchResults.length > 0}}"
  >
    <view class="search-results">
      <view class="result-header">
        <text class="result-count">找到 {{searchResults.length}} 篇相关文章</text>
        <text class="filter-badge" wx:if="{{currentAgeFilter !== 'all'}}">
          {{ageFilters.find(f => f.id === currentAgeFilter)?.name}}
        </text>
      </view>

      <!-- 文章列表 -->
      <view class="article-list">
        <view 
          class="article-card" 
          wx:for="{{searchResults}}" 
          wx:key="id" 
          bindtap="readArticle" 
          data-id="{{item.id}}"
        >
          <text class="article-title">{{item.highlightTitle || item.title}}</text>
          <text class="article-summary">{{item.highlightSummary || item.summary}}</text>
          <view class="article-meta">
            <text class="article-category">{{item.category}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 空结果 -->
  <view class="empty-result" wx:if="{{searched && searchResults.length === 0}}">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">没有找到相关文章</text>
    <text class="empty-hint">换个关键词试试吧</text>
  </view>

  <!-- 初始状态提示 -->
  <view class="initial-hint" wx:if="{{!searched && searchHistory.length === 0}}">
    <text class="hint-icon">💡</text>
    <text class="hint-text">搜索育儿知识</text>
    <text class="hint-detail">试试搜索：不睡觉、哭闹、发烧</text>
  </view>
</view>
