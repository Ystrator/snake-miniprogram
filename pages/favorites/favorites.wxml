<!--收藏页面 - P3优化版本（增强分类功能）-->
<view class="container {{darkMode ? 'dark-mode' : ''}}">
  <view class="favorites-header">
    <text class="header-title">⭐ 我的收藏</text>
    <text class="header-count">{{favorites.length}} 篇文章</text>
  </view>

  <!-- 分类管理 -->
  <view class="category-section" wx:if="{{categories.length > 0}}">
    <view class="category-header">
      <scroll-view class="category-scroll" scroll-x>
        <view class="category-tabs">
          <text class="category-tab {{activeCategory === 'all' ? 'active' : ''}}" 
                bindtap="switchCategory" data-category="all">
            全部
          </text>
          <text class="category-tab {{activeCategory === item.id ? 'active' : ''}}" 
                wx:for="{{categories}}" wx:key="id" wx:for-item="category"
                bindtap="switchCategory" data-category="{{category.id}}">
            {{category.name}} ({{category.count}})
          </text>
        </view>
      </scroll-view>
      <text class="add-category-btn" bindtap="showAddCategoryModal">
        <text class="add-icon">+</text>
      </text>
    </view>
    
    <!-- 分类操作按钮 -->
    <view class="category-actions" wx:if="{{activeCategory !== 'all'}}">
      <text class="action-btn" bindtap="editCategory">
        <text class="action-icon">✏️</text>
        <text class="action-text">编辑分类</text>
      </text>
      <text class="action-btn delete" bindtap="deleteCategory">
        <text class="action-icon">🗑️</text>
        <text class="action-text">删除分类</text>
      </text>
    </view>
  </view>

  <!-- 搜索和筛选栏 -->
  <view class="filter-bar" wx:if="{{favorites.length > 0}}">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input"
             placeholder="搜索收藏的文章..."
             value="{{searchKeyword}}"
             bindinput="onSearchInput" />
    </view>
    <view class="sort-buttons">
      <text class="sort-btn {{sortBy === 'date' ? 'active' : ''}}" bindtap="sortByField" data-field="date">
        <text class="sort-icon">📅</text>
        时间
      </text>
      <text class="sort-btn {{sortBy === 'category' ? 'active' : ''}}" bindtap="sortByField" data-field="category">
        <text class="sort-icon">📂</text>
        分类
      </text>
    </view>
  </view>

  <!-- 收藏列表（支持拖拽排序） -->
  <view class="favorites-list" wx:if="{{filteredFavorites.length > 0}}">
    <view class="article-item" 
          wx:for="{{filteredFavorites}}" 
          wx:key="id" 
          bindtap="readArticle" 
          data-id="{{item.id}}"
          bindlongpress="startDrag"
          data-index="{{index}}">
      <view class="drag-handle" wx:if="{{sortBy === 'custom'}}">
        <text class="drag-icon">⋮⋮</text>
      </view>
      <view class="article-content">
        <text class="article-title">{{item.title}}</text>
        <text class="article-summary">{{item.summary}}</text>
        <view class="article-meta">
          <text class="article-category">{{item.categoryName}}</text>
          <text class="article-date">{{item.favoriteDate || '收藏于 ' + item.publishDate}}</text>
        </view>
        <view class="article-actions">
          <text class="action-tag" bindtap="showMoveToModal" data-id="{{item.id}}" catchtap="stopPropagation">
            📁 移动
          </text>
          <text class="action-tag remove" bindtap="removeFavorite" data-id="{{item.id}}" catchtap="stopPropagation">
            ❌ 取消收藏
          </text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{favorites.length === 0}}">
    <text class="empty-icon">⭐</text>
    <text class="empty-text">还没有收藏的文章</text>
    <text class="empty-hint">去发现更多育儿知识吧</text>
  </view>

  <view class="empty-state" wx:if="{{favorites.length > 0 && filteredFavorites.length === 0}}">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">没有找到匹配的文章</text>
    <text class="empty-hint">试试其他搜索词或分类</text>
  </view>

  <!-- 添加分类弹窗 -->
  <view class="modal-overlay" wx:if="{{showAddCategoryModal}}" bindtap="hideAddCategoryModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">📁 新建分类</text>
        <text class="modal-close" bindtap="hideAddCategoryModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <text class="form-label">分类名称</text>
          <input class="form-input" 
                 placeholder="请输入分类名称"
                 value="{{newCategoryName}}"
                 bindinput="onCategoryNameInput"
                 maxlength="20"/>
          <text class="char-count">{{newCategoryName.length}}/20</text>
        </view>
        <view class="form-group">
          <text class="form-label">选择图标（可选）</text>
          <view class="icon-selector">
            <text class="icon-option {{selectedCategoryIcon === item ? 'active' : ''}}" 
                  wx:for="{{categoryIcons}}" wx:key="*this"
                  bindtap="selectCategoryIcon" data-icon="{{item}}">
              {{item}}
            </text>
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">选择颜色（可选）</text>
          <view class="color-selector">
            <text class="color-option {{selectedCategoryColor === item ? 'active' : ''}}" 
                  style="background: {{item}}"
                  wx:for="{{categoryColors}}" wx:key="*this"
                  bindtap="selectCategoryColor" data-color="{{item}}">
            </text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn secondary" bindtap="hideAddCategoryModal">取消</button>
        <button class="modal-btn primary" bindtap="addCategory" disabled="{{!newCategoryName}}">
          创建
        </button>
      </view>
    </view>
  </view>

  <!-- 移动到分类弹窗 -->
  <view class="modal-overlay" wx:if="{{showMoveToModal}}" bindtap="hideMoveToModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">📁 移动到分类</text>
        <text class="modal-close" bindtap="hideMoveToModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="category-list">
          <text class="category-option {{selectedMoveCategory === 'uncategorized' ? 'active' : ''}}" 
                bindtap="selectMoveCategory" data-category="uncategorized">
            📂 未分类
          </text>
          <text class="category-option {{selectedMoveCategory === item.id ? 'active' : ''}}" 
                wx:for="{{categories}}" wx:key="id" wx:for-item="category"
                bindtap="selectMoveCategory" data-category="{{category.id}}">
            {{category.icon}} {{category.name}}
          </text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn secondary" bindtap="hideMoveToModal">取消</button>
        <button class="modal-btn primary" bindtap="confirmMove">确定</button>
      </view>
    </view>
  </view>
</view>
