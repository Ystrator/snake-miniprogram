/* 收藏页面样式 */
.container {
  min-height: 100vh;
  padding: 32rpx;
}

.favorites-header {
  padding: 32rpx 0;
  margin-bottom: 32rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 8rpx;
}

.header-count {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.article-item {
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
}

.article-content {
  flex: 1;
}

.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 12rpx;
}

.article-summary {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.8;
}

.article-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.article-category {
  font-size: 24rpx;
  color: var(--primary-color);
  padding: 4rpx 12rpx;
  background: rgba(0, 122, 255, 0.1);
  border-radius: 12rpx;
}

.remove-btn {
  font-size: 24rpx;
  color: var(--danger-color);
  padding: 8rpx 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 筛选栏样式 */
.filter-bar {
  margin-bottom: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #F5F5F7;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.category-filter {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
}

.filter-item {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F5F7;
  border-radius: 24rpx;
  transition: all 0.2s;
}

.filter-item.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
