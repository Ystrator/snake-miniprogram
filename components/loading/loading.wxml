<!--components/loading/loading.wxml-->
<view class="loading-container" wx:if="{{show}}">
  <view class="loading-wrapper">
    <!-- 加载动画 -->
    <view class="loading-spinner">
      <view class="spinner-dot"></view>
      <view class="spinner-dot"></view>
      <view class="spinner-dot"></view>
    </view>
    
    <!-- 加载文字 -->
    <view class="loading-text" wx:if="{{text}}">
      {{text}}
    </view>
    
    <!-- 进度条（可选） -->
    <view class="loading-progress" wx:if="{{showProgress}}">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progress}}%"></view>
      </view>
      <view class="progress-text">{{progress}}%</view>
    </view>
  </view>
</view>
