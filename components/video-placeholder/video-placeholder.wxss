/* 视频占位符样式 */
.video-placeholder {
  width: 100%;
  height: 400rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.video-placeholder.dark {
  background: #2C2C2E;
}

.video-placeholder .icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.video-placeholder .text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 10rpx;
}

.video-placeholder.dark .text {
  color: #E5E5E5;
}

.video-placeholder .hint {
  font-size: 24rpx;
  color: #999999;
}

.video-placeholder.dark .hint {
  color: #A0A0A0;
}
