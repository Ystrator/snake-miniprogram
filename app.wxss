/* iOS 设计风格 - 全局样式 - 优化配色方案 */

page {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
  background-color: #F5F5F7;  /* 稍微深一点的背景，减少刺眼的白色 */
  line-height: 1.6;
  transition: background-color 0.3s;
}

/* 夜间模式 */
page.dark-mode {
  background-color: #000000;
  color: #ffffff;
}

/* iOS 标准配色 - 浅色模式（优化版） */
:root {
  --primary-color: #007AFF;
  --success-color: #34C759;
  --warning-color: #FF9500;
  --danger-color: #FF3B30;
  --background-color: #F5F5F7;  /* 优化：浅灰蓝色背景 */
  --card-background: #FFFFFF;     /* 保持纯白卡片 */
  --card-background-hover: #F9F9FB;  /* 添加悬停背景 */
  --text-primary: #000000;
  --text-secondary: #666666;   /* 加深灰色，增强对比度 */
  --border-color: #E0E0E0;     /* 加深的边框颜色 */
  --shadow-color: rgba(0, 0, 0, 0.08);
  --gradient-start: #667eea;
  --end-color: #764ba2;
  --card-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);  /* 加深阴影 */
  --section-bg: #FAFAFC;     /* 章节背景色，略深于整体背景 */
  --highlight-bg: #FFF8E1;     /* 高亮背景色 */
}

/* iOS 标准配色 - 深色模式（优化版） */
page.dark-mode {
  --primary-color: #0A84FF;
  --success-color: #32D74B;
  --warning-color: #FF9F0A;
  --danger-color: #FF453A;
  --background-color: #1A1A1D;     /* 深灰色背景，不是纯黑 */
  --card-background: #2C2C2E;     /* 深灰色卡片 */
  --card-background-hover: #343436;
  --text-primary: #FFFFFF;
  --text-secondary: #A0A0A0;
  --border-color: #3A3A3C;
  --shadow-color: rgba(0, 0, 0, 0.3);
  --gradient-start: #5856D6;
  --gradient-end: #AF52DE;
  --card-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  --section-bg: #1E1E20;     /* 深色章节背景 */
  --highlight-bg: #2A2A2D;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  padding-bottom: 100rpx;
  background-color: var(--background-color);  /* 使用CSS变量 */
}

/* iOS 风格卡片（优化版） */
.card {
  background: var(--card-background);
  border-radius: 12rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: var(--card-shadow);
  border: 1rpx solid var(--border-color);  /* 添加边框增强对比 */
}

/* 卡片悬停效果（浅色模式） */
.card:active {
  background: var(--card-background-hover);
}

/* 文本样式（优化对比度） */
.text-primary {
  color: var(--text-primary);
  font-weight: 600;
}

.text-secondary {
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* 小标签样式（优化） */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #F0F0F0;  /* 更明显的灰色背景 */
  color: #666666;
  border-radius: 16rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.tag.primary {
  background: rgba(0, 122, 255, 0.08);
  color: var(--primary-color);
}

.tag.warning {
  background: rgba(255, 149, 0, 0.08);
  color: var(--warning-color);
}

.tag.danger {
  background: rgba(255, 59, 48, 0.08);
  color: var(--danger-color);
}

/* 章节背景（新增） */
.section-bg {
  background: var(--section-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

/* 高亮背景（新增） */
.highlight-bg {
  background: var(--highlight-bg);
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
}

/* 卡片组优化 */
.card-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 优化按钮样式 */
.btn {
  background: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s;
  box-shadow: 0 2rpx 8rpx rgba(0, 122, 255, 0.3);
}

.btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-secondary {
  background: #F0F0F0;
  color: #666666;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.btn-secondary:active {
  background: #E5E5EA;
}

/* 列表项优化 */
.list-item {
  background: var(--card-background);
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: background 0.2s;
}

.list-item:active {
  background: var(--card-background-hover);
}

/* Modal 弹窗优化 */
.modal-content {
  background: var(--card-background);
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  max-height: 80vh;
  overflow-y: auto;
  border: 1rpx solid var(--border-color);
}

/* 搜索框优化 */
.search-box {
  background: var(--card-background);
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-placeholder {
  color: #999999;
  font-size: 28rpx;
}

/* 快捷按钮优化 */
.quick-btn {
  background: #FFFFFF;
  border: 1rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.quick-btn:active {
  background: #F8F8F8;
  transform: scale(0.98);
}

/* 分类卡片优化 */
.age-card {
  background: #FFFFFF;
  border: 1rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.age-card:active {
  background: #F8F8F8;
  transform: scale(0.98);
}

/* 文章卡片优化 */
.article-card {
  background: #FFFFFF;
  border: 1rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  transition: all 0.2s;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.article-card:active {
  background: #F8F8F8;
}

/* 夜间模式优化 */
page.dark-mode .card {
  background: #2C2C2E;
  border-color: #3A3A3C;
}

page.dark-mode .tag {
  background: #3A3A3C;
  color: #A0A0A0;
}

page.dark-mode .btn-secondary {
  background: #3A3A3C;
  color: #B0B0B0;
}

page.dark-mode .quick-btn {
  background: #2C2C2E;
  border-color: #3A3A3C;
}

page.dark-mode .age-card {
  background: #2C2C2E;
  border-color: #3A3A3C;
}

page.dark-mode .article-card {
  background: #2C2C2E;
  border-color: #3A3A3C;
}

page.dark-mode .list-item {
  background: #2C2C2E;
  border-color: #3A3A3C;
}

page.dark-mode .list-item:active {
  background: #343436;
}

/* 弹窗标题 */
.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 32rpx;
}

/* 弹窗内容 */
.emergency-item {
  background: var(--section-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 紧急按钮 */
.emergency-btn {
  background: #FFF4F4;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.emergency-btn:active {
  background: #FFE5E5;
  transform: scale(0.98);
}

/* 修复夜间模式下的紧急按钮样式 */
page.dark-mode .emergency-btn {
  background: #2D3D30;
}

/* 改善对比度 */
.section-title {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.article-title {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.article-summary {
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

/* 优化标题和图标颜色 */
.page-name,
.baby-name-text,
.baby-age-value {
  color: var(--text-primary);
}

.search-hint,
.tip-arrow,
.tip-text {
  color: var(--text-secondary);
}

/* 骁体样式优化 */
.emergency-item-title {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.emergency-steps {
  padding-left: 0;
}

.step-item {
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.step-number {
  color: var(--primary-color);
  font-weight: 600;
}

/* 标签样式优化 */
.mini-tag {
  background: #F0F0F0;
  color: #666666;
  border-radius: 8rpx;
  padding: 4rpx 8rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
  margin-bottom: 8r;
}

/* 间距优化 */
.status-bar {
  padding: 20rpx 32rpx;
  background: var(--card-background);
  border-bottom: 1rpx solid var(--border-color);
}

.baby-age-card {
  background: var(--card-background);
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 搜索区域 */
.search-hero {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 48rpx 32rpx;
  border-radius: 16rpx;
  margin: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 分类区域 */
.age-section,
.articles-section {
  background: transparent;
}

/* 技影效果 */
.shadow {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

/* 空状态 */
.empty-icon {
  color: #C7C7CC;
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-text {
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  color: var(--text-secondary);
}

/* 滚动岛区域 */
.status-actions {
  gap: 24rpx;
}

/* 页面切换动画 */
.transition {
  transition: all 0.3s;
}
